{
  "name": "nextify-monorepo",
  "private": false,
  "version": "0.1.23",
  "description": "Nextify.js — Modern React framework with file-based routing, SSR and a Vite-powered dev server.",
  "author": {
    "name": "Ricardo Oliveira",
    "url": "https://github.com/RicardoOliver"
  },
  "license": "MIT",
  "homepage": "https://github.com/RicardoOliver/Nextify.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RicardoOliver/Nextify.js.git"
  },
  "bugs": {
    "url": "https://github.com/RicardoOliver/Nextify.js/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/RicardoOliver"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@9",
  "keywords": [
    "nextify",
    "react",
    "react-framework",
    "vite",
    "ssr",
    "javascript-framework",
    "frontend-framework",
    "web-framework",
    "file-based-routing",
    "developer-tools",
    "modern-web",
    "nextjs-alternative",
    "fullstack-framework",
    "react-ssr",
    "web-development"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "dev": "npm --workspace @nextify/dev-server run dev",
    "typecheck": "npm run --workspaces --if-present typecheck",
    "test": "npm run --workspaces --if-present test",
    "lint": "eslint . --ext .js,.mjs,.cjs --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs --fix",
    "format": "prettier --write package.json .prettierrc.json .github/settings.yml .github/workflows/ci.yml eslint.config.mjs scripts/validate-commits.mjs",
    "format:check": "prettier --check package.json .prettierrc.json .github/settings.yml .github/workflows/ci.yml eslint.config.mjs scripts/validate-commits.mjs",
    "validate": "npm run version:check && npm run lint && npm run format:check && npm run typecheck && npm run test",
    "commitlint": "node scripts/validate-commits.mjs",
    "example:reference": "node examples/reference-app/server.mjs",
    "test:e2e": "npm --workspace @nextify/core run test -- tests/referenceApp.e2e.test.ts",
    "sbom:generate": "node scripts/generate-sbom.mjs",
    "provenance:verify": "node scripts/verify-provenance-policy.mjs",
    "audit:internal": "node scripts/run-internal-audit.mjs",
    "changeset": "npx @changesets/cli",
    "changeset:version": "npx @changesets/cli version",
    "changeset:status": "npx @changesets/cli status --verbose",
    "version:check": "node scripts/check-version-drift.mjs",
    "benchmark:synthetic": "node scripts/run-synthetic-benchmark.mjs",
    "benchmark:regression": "node scripts/check-performance-regression.mjs",
    "engineering-health:panel": "node scripts/generate-engineering-health-panel.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.39.1",
    "prettier": "^3.7.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
