{
  "name": "nextify-monorepo",
  "private": false,
  "version": "0.1.19",
  "description": "Nextify.js monorepo (public)",

  "author": "Ricardo Oliveira",

  "license": "MIT",

  "repository": {
    "type": "git",
    "url": "https://github.com/RicardoOliver/Nextify.js.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "dev": "npm --workspace @nextify/dev-server run dev",
    "typecheck": "npm run --workspaces --if-present typecheck",
    "test": "npm run --workspaces --if-present test",
    "lint": "eslint . --ext .js,.mjs,.cjs --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs --fix",
    "format": "prettier --write package.json .prettierrc.json .github/settings.yml .github/workflows/ci.yml eslint.config.mjs scripts/validate-commits.mjs",
    "format:check": "prettier --check package.json .prettierrc.json .github/settings.yml .github/workflows/ci.yml eslint.config.mjs scripts/validate-commits.mjs",
    "validate": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "commitlint": "node scripts/validate-commits.mjs",
    "example:reference": "node examples/reference-app/server.mjs",
    "test:e2e": "npm --workspace @nextify/core run test -- tests/referenceApp.e2e.test.ts",
    "sbom:generate": "node scripts/generate-sbom.mjs",
    "audit:internal": "node scripts/run-internal-audit.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.39.1",
    "prettier": "^3.7.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
 }
